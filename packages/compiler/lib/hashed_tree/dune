(rule
 (with-stdout-to
  template_js.ml
  (progn
   (echo "let template = {|")
   (cat ./templates/template.js.jinja)
   (echo "|}")
   (echo "let runtime = {|")
   (cat ../../runtimes/runtime.js)
   (echo "|}"))
))

