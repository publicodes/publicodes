(rule
 (with-stdout-to
  js_template.ml
  (progn
   (echo "let template = {|")
   (cat ./templates/js_template.jinja)
   (echo "|}")
   (echo "let runtime = {|")
   (cat ../../runtimes/runtime.js)
   (echo "|}"))))

