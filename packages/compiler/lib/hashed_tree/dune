(library
 (inline_tests)
 (name hashed_tree)
 (public_name publicodes.hashed_tree)
 (libraries base yojson typed_tree shared jingoo)
 (modules :standard)
 (preprocess
  (pps
   ppx_assert
   ppx_compare
   ppx_deriving.show
   ppx_inline_test
   ppx_sexp_conv
