{%- macro fmt_binop (op) %}
	{%- switch op %}
	{%- case "add" -%} +
	{%- case "sub" -%} -
	{%- case "mul" -%} *
	{%- case "div" -%} /
	{%- case "pow" -%} **
	{%- case "eq" -%} =
	{%- case "neq" -%} !=
	{%- case "lt" -%} <
	{%- case "gt" -%} >
	{%- case "gte" -%} >=
	{%- case "lte" -%} <=
	{%- case "and" -%} &&
	{%- case "or" -%} ||
	{%- case "min" -%} min
	{%- case "max" -%} max
	{%- endswitch %}
{%- endmacro %}

{%- macro fmt_unop (op) %}
	{%- switch op %}
	{%- case "neg_op" -%} -
	{%- case "is_not_defined_op" -%} is_not_defined
	{%- endswitch %}
{%- endmacro %}

{%- macro fmt_node_unit (unit) %}
	{%- if unit && unit != "aucune" %} {{ unit }}{% endif %}
{%- endmacro %}

{%- function needs_parens (op) %}
	{{ op == "binary_op" || op == "unary_op" }}
{%- endfunction %}

{%- macro fmt_operand (node) %}
	{%- if needs_parens(node.node_type) %}({% endif -%}
	{{ fmt_node(node) }}
	{%- if needs_parens(node.node_type) %}){% endif -%}
{%- endmacro %}

{%- macro indent (prefix) -%}
{%- set input -%}{{ caller() }}{%- endset -%}
{{ replace ("\n", "\n" + prefix, input) }}
{%- endmacro -%}


{%- macro fmt_node (node) %}
{%- set node_type, node_value = (node.node_type, node.node_value) -%}
{%- switch node_type %}

{%- case "number" -%}
{{ node_value.number }}{{ fmt_node_unit (node_value.unit) }}

{%- case "text" -%}
"{{ node_value }}"

{%- case "bool" -%}
{{ node_value }}

{%- case "date" -%}
{%- if node_value.day -%}
Shared_ast.Day {day = {{ node_value.day }}; year = {{ node_value.year }}; month = {{ node_value.month}}}
{%- else -%}
Shared_ast.Month {month = {{ node_value.month}}; year = {{ node_value.year }}}
{%- endif %}

{%- case "not_applicable" -%}
not_applicable

{%- case "not_defined" -%}
not_defined

{%- case "round" -%}
round {% if node_value.mode != "nearest" %}{{ node_value.mode }} {% endif %}to:
{%- call indent ("  ") %} {{ fmt_node(node_value.precision) }}
{%- endcall %}
{{ fmt_node(node_value.number) }}

{%- case "condition" -%}
if
{%- call indent ("  ") %} {{
	fmt_node(node_value.cond) }}
{%- endcall %}
then
{%- call indent ("  ") %} {{
	fmt_node(node_value.then) }}
{%- endcall %}
else
{%- call indent ("  ") %} {{
	fmt_node(node_value._else) }}
{%- endcall %}

{%- case "binary_op" -%}
{{ fmt_operand(node_value.left) }} {{ fmt_binop(node_value.op) }} {{ fmt_operand(node_value.right) }}

{%- case "unary_op" -%}
{{ fmt_unop(node_value.op) }} {{ fmt_node(node_value.arg) }}

{%- case "ref" -%}
@{{ node_value }}

{%- case "get_ctx" -%}
get_context({{ node_value }})

{%- case "set_ctx" -%}
with
{
{%- for item in node_value.items %}
{%- set item_name, item_value = (item.name, item.value) %}
{{ item_name }} = {{ fmt_node(item_value) }}
{%- endfor %}
}
in
{{ fmt_node(node_value.expr) }}
{%- endswitch %}
{%- endmacro %}

{%- for rule_type, rule_name, rule_node in rules %}
{%- if !loop.first %}

{% endif -%}
{{ rule_name }}:
{%- call indent ("  ") %}
{{ fmt_node(rule_node) }}
{%- endcall %}
{%- endfor -%}
