[access]
	inheritFrom = All-Projects
[submit]
[project]
	description = Le langage pour les algorithmes d'int�r�t public
[access "refs/*"]
	owner = group user/Willow (stacyharper)
[access "refs/for/refs/*"]
	label-Code-Review = -2..+2 group user/Willow (stacyharper)
	label-Verified = -1..+1 group user/Willow (stacyharper)
	push = group user/Willow (stacyharper)
	read = group user/Willow (stacyharper)
	rebase = group user/Willow (stacyharper)
	removeReviewer = group user/Willow (stacyharper)
	submit = group user/Willow (stacyharper)
[access "refs/heads/*"]
	create = group user/Willow (stacyharper)
	push = +force group user/Willow (stacyharper)
	pushMerge = group user/Willow (stacyharper)
	read = group user/Willow (stacyharper)
[access "refs/tags/*"]
	push = group user/Willow (stacyharper)
	push = +force group user/Willow (stacyharper)
[submit-requirement "Sticky-Code-Review"]
	submittableIf = -label:Sticky-Code-Review=MIN
	canOverrideInChildProjects = false
